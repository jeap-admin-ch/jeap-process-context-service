{
  "title": "JEAP Process Context UI",
  "name": "jeap-process-context-ui",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "organization": {
    "name": "Federal Office of Information Technology, Systems and Telecommunication FOITT",
    "url": "http://www.bit.admin.ch/"
  },
  "scripts": {
    "start": "ng serve",
    "build": "ng build --base-href /process-context/",
    "build-prod": "ng build -c production --base-href /process-context/",
    "cypress:run": "cypress run --config video=false --component",
    "check-licenses": "apache2-license-checker",
    "generateLicenseFile": "license-checker --customPath custom-license-md-format.json --markdown > ../THIRD-PARTY-FRONTEND-LICENSES.md"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@ngx-translate/core": "^17.0.0",
    "@oblique/oblique": "^15.1.2",
    "@popperjs/core": "^2.11.8",
    "@quadrel-enterprise-ui/auth": "20.1.0-beta.27.1",
    "angular-oauth2-oidc": "^20.0.2",
    "cypress": "^15.12.0",
    "jwt-decode": "^4.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.5.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular-builders/jest": "^21.0.3",
    "@angular-eslint/builder": "21.3.1",
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/schematics": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/build": "^21.2.3",
    "@angular/cli": "~21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@bbc/apache2-license-checker": "^1.1.4",
    "@cypress/vite-dev-server": "^7.2.1",
    "@schematics/angular": "^21.2.3",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "8.46.2",
    "@typescript-eslint/parser": "8.46.2",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.4",
    "husky": "^8.0.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-sonar-reporter": "2.0.0",
    "js-cookie": "^3.0.5",
    "license-checker": "^25.0.1",
    "ng-mocks": "^14.15.2",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "jestSonar": {
    "reportPath": "./coverage/sonarQube",
    "reportFile": "sqr.xml",
    "indent": 4,
    "sonar56x": true
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run format"
    }
  }
}
